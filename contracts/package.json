{
  "name": "agrovida-contracts",
  "version": "1.0.0",
  "description": "AGROVIDA Token smart contracts — ERC-20 + Staking",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
